{
    "rules": [
        {
            "id": "R001",
            "name": "名称混淆禁止",
            "category": "SAFETY",
            "severity": "HIGH",
            "description": "名称相似的拖轮(如亚洲1号、亚洲2号)不能同时分配给同一作业，避免调度混乱",
            "check_logic": "name_similarity(tug1, tug2) > 0.8",
            "keywords": [
                "亚洲",
                "名称",
                "混淆",
                "相似"
            ],
            "enabled": true
        },
        {
            "id": "R002",
            "name": "老旧拖轮高危限制",
            "category": "SAFETY",
            "severity": "CRITICAL",
            "description": "船龄超过20年的拖轮不得执行高危作业(危化品、LNG等)",
            "check_logic": "tug.ship_age > 20 and job.is_high_risk == true",
            "keywords": [
                "老旧",
                "船龄",
                "高危",
                "危化品"
            ],
            "enabled": true
        },
        {
            "id": "R003",
            "name": "马力匹配要求",
            "category": "SAFETY",
            "severity": "HIGH",
            "description": "分配的拖轮总马力必须满足任务需求马力",
            "check_logic": "sum(assigned_tugs.horsepower) >= job.required_horsepower",
            "keywords": [
                "马力",
                "匹配",
                "需求"
            ],
            "enabled": true
        },
        {
            "id": "R004",
            "name": "疲劳船员禁派",
            "category": "SAFETY",
            "severity": "CRITICAL",
            "description": "疲劳值达到红色等级(>10)的拖轮禁止分配任何任务",
            "check_logic": "tug.fatigue_level != 'RED'",
            "keywords": [
                "疲劳",
                "休息",
                "安全"
            ],
            "enabled": true
        },
        {
            "id": "R005",
            "name": "夜间作业资质",
            "category": "COMPLIANCE",
            "severity": "MEDIUM",
            "description": "22:00-06:00期间的作业需要具备夜间作业资质的船员",
            "check_logic": "job.start_time.hour >= 22 or job.start_time.hour < 6",
            "keywords": [
                "夜间",
                "资质",
                "证书"
            ],
            "enabled": true
        },
        {
            "id": "R006",
            "name": "内档船移泊优先",
            "category": "EFFICIENCY",
            "severity": "LOW",
            "description": "优先使用外档船，使用内档船需先安排移泊操作",
            "check_logic": "tug.berth_position == 'INNER'",
            "keywords": [
                "内档",
                "外档",
                "移泊"
            ],
            "enabled": true
        },
        {
            "id": "R007",
            "name": "连续作业限制",
            "category": "SAFETY",
            "severity": "MEDIUM",
            "description": "同一拖轮连续作业不得超过4小时，需安排休息",
            "check_logic": "tug.today_work_hours > 4",
            "keywords": [
                "连续",
                "作业",
                "休息",
                "时长"
            ],
            "enabled": true
        },
        {
            "id": "R008",
            "name": "危化品专用泊位",
            "category": "COMPLIANCE",
            "severity": "CRITICAL",
            "description": "危化品船舶必须在指定的危化品泊位作业",
            "check_logic": "job.is_high_risk and berth.berth_type == 'HAZARDOUS'",
            "keywords": [
                "危化品",
                "泊位",
                "专用"
            ],
            "enabled": true
        },
        {
            "id": "R009",
            "name": "作业均衡分配",
            "category": "EFFICIENCY",
            "severity": "LOW",
            "description": "优先分配给今日工作量较少的拖轮，保证作业均衡",
            "check_logic": "balance_score(all_tugs) > 0.7",
            "keywords": [
                "均衡",
                "分配",
                "公平"
            ],
            "enabled": true
        },
        {
            "id": "R010",
            "name": "连活优先识别",
            "category": "EFFICIENCY",
            "severity": "MEDIUM",
            "description": "间隔小于2小时且距离小于5海里的连续任务应识别为连活，优先同船执行",
            "check_logic": "interval_hours < 2 and distance_nm < 5",
            "keywords": [
                "连活",
                "间隔",
                "距离",
                "节省"
            ],
            "enabled": true
        }
    ]
}